<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="two_wheeled_robot">

    <!-- ==================================================================== -->
    <!-- XACRO PROPERTIES (Dimensions in meters, mass in kg)                  -->
    <!-- ==================================================================== -->
    
    <!-- Main Box Chassis -->
    <xacro:property name="base_length" value="0.40"/>
    <xacro:property name="base_width" value="0.30"/>
    <xacro:property name="base_height" value="0.12"/>
    <xacro:property name="base_mass" value="5.0"/>

    <!-- Wheels -->
    <xacro:property name="wheel_radius" value="0.06"/>
    <xacro:property name="wheel_length" value="0.04"/>
    <xacro:property name="wheel_mass" value="0.5"/>
    <xacro:property name="wheel_offset_y" value="${(base_width / 2) + (wheel_length / 2)}"/>
    <xacro:property name="wheel_offset_z" value="0.03"/>

    <!-- Caster Wheel -->
    <xacro:property name="caster_radius" value="0.03"/>
    <xacro:property name="caster_mass" value="0.2"/>
    <xacro:property name="caster_offset_x" value="0.15"/>

    <!-- ==================================================================== -->
    <!-- INERTIAL MACROS                                                      -->
    <!-- ==================================================================== -->
    <xacro:macro name="cylinder_inertia" params="mass radius length">
        <inertial>
            <mass value="${mass}"/>
            <inertia ixx="${(1/12) * mass * (3 * radius*radius + length*length)}" ixy="0.0" ixz="0.0"
                     iyy="${(1/12) * mass * (3 * radius*radius + length*length)}" iyz="0.0"
                     izz="${(1/2) * mass * radius*radius}"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="sphere_inertia" params="mass radius">
        <inertial>
            <mass value="${mass}"/>
            <inertia ixx="${(2/5) * mass * radius*radius}" ixy="0.0" ixz="0.0"
                     iyy="${(2/5) * mass * radius*radius}" iyz="0.0"
                     izz="${(2/5) * mass * radius*radius}"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="box_inertia" params="mass x y z">
        <inertial>
            <mass value="${mass}"/>
            <inertia ixx="${(1/12) * mass * (y*y + z*z)}" ixy="0.0" ixz="0.0"
                     iyy="${(1/12) * mass * (x*x + z*z)}" iyz="0.0"
                     izz="${(1/12) * mass * (x*x + y*y)}"/>
        </inertial>
    </xacro:macro>

    <!-- ==================================================================== -->
    <!-- MATERIALS                                                            -->
    <!-- ==================================================================== -->
    <material name="blue"><color rgba="0.2 0.6 0.9 1.0"/></material>
    <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
    <material name="red"><color rgba="0.8 0.1 0.1 1.0"/></material>

    <!-- ==================================================================== -->
    <!-- ROBOT LINKS & JOINTS                                                 -->
    <!-- ==================================================================== -->

    <!-- 1. BASE FOOTPRINT -->
    <link name="base_footprint"/>

    <!-- 2. BASE LINK -->
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${wheel_radius + wheel_offset_z}" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
        </collision>
        <xacro:box_inertia mass="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
    </link>

    <!-- 3 & 4. LEFT AND RIGHT WHEELS -->
    <xacro:macro name="wheel" params="prefix side">
        <joint name="${prefix}_wheel_joint" type="continuous">
            <parent link="base_link"/>
            <child link="${prefix}_wheel"/>
            <origin xyz="0 ${side * wheel_offset_y} -${wheel_offset_z}" rpy="-${pi/2} 0 0"/>
            <axis xyz="0 0 1"/>
        </joint>

        <link name="${prefix}_wheel">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
                </geometry>
                <material name="black"/>
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
                </geometry>
            </collision>
            <xacro:cylinder_inertia mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_length}"/>
        </link>
    </xacro:macro>

    <xacro:wheel prefix="left" side="1"/>
    <xacro:wheel prefix="right" side="-1"/>

    <!-- 5. CASTER WHEEL -->
    <joint name="caster_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel"/>
        <origin xyz="${caster_offset_x} 0 -${wheel_radius + wheel_offset_z - caster_radius}" rpy="0 0 0"/>
    </joint>

    <link name="caster_wheel">
        <visual>
            <geometry>
                <sphere radius="${caster_radius}"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${caster_radius}"/>
            </geometry>
        </collision>
        <xacro:sphere_inertia mass="${caster_mass}" radius="${caster_radius}"/>
    </link>

    <!-- 6. LIDAR LINK -->
    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <!-- Added a +0.025 Z-offset to raise the mesh out of the chassis -->
        <origin xyz="0 0 ${base_height/2 + 0.025}" rpy="0 0 0"/>
    </joint>

    <link name="lidar_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
              <mesh filename="package://robot_description_youssef_ahmed/meshes/lidar.stl" scale="1 1 1"/>
            </geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
        </collision>
        <xacro:box_inertia mass="0.15" x="0.1" y="0.1" z="0.08"/>
    </link>

    <!-- 7. CAMERA LINK -->
    <joint name="camera_joint" type="fixed">
        <parent link="base_link"/>
        <child link="camera_link"/>
        <!-- Added a +0.02 X-offset to push the mesh forward out of the chassis -->
        <origin xyz="${base_length/2 + 0.02} 0 ${base_height/4}" rpy="0 0 0"/>
    </joint>

    <link name="camera_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://robot_description_youssef_ahmed/meshes/zed.stl" scale="1 1 1"/>
            </geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.03 0.08 0.03"/>
            </geometry>
        </collision>
        <xacro:box_inertia mass="0.05" x="0.03" y="0.08" z="0.03"/>
    </link>

</robot>